NodeId: edge-rpi-01

TCP:  { Enabled: true,  Port: 1883, Address: "0.0.0.0" }  # use "::" for IPv6
TCPS: { Enabled: false, Port: 8883, Address: "0.0.0.0", KeyStorePath: "cert.pem:key.pem", KeyStorePassword: "" }
# TCPS with mTLS: { Enabled: false, Port: 8883, KeyStorePath: "cert.pem:key.pem", CaFilePath: "ca.pem", RequireClientCert: true }
WS:   { Enabled: true,  Port: 1884, Address: "0.0.0.0" }
WSS:  { Enabled: false, Port: 8884, Address: "0.0.0.0", KeyStorePath: "cert.pem:key.pem", KeyStorePassword: "" }
MaxMessageSize: 1048576

DefaultStoreType: SQLITE
SessionStoreType: MEMORY
RetainedStoreType: MEMORY
ConfigStoreType: SQLITE
QueueStoreType: MEMORY

SQLite:
  Path: ./data/monstermq.db

Postgres:
  Url: "postgres://localhost:5432/monstermq"
  User: monstermq
  Pass: monstermq

MongoDB:
  Url: "mongodb://localhost:27017"
  Database: monstermq

UserManagement:
  Enabled: false
  PasswordAlgorithm: BCRYPT
  AnonymousEnabled: true
  AclCacheEnabled: true
  # AclCheckOnSubscription: false  # When false, wildcard subscriptions are allowed; ACL enforced at delivery time.

Metrics:
  Enabled: true
  StoreType: MEMORY
  CollectionIntervalSeconds: 1
  RetentionHours: 168
  MaxHistoryRows: 3600

Logging:
  Level: INFO
  MqttSyslogEnabled: false
  RingBufferSize: 1000

GraphQL:
  Enabled: true
  Port: 8080

Features:
  MqttClient: true
  WinCCUa: false
  WinCCOa: false
  DeviceImportExport: true

# QueuedMessagesEnabled: true  -> use QueueStoreType for offline persistent
# (clean=false) sessions. With QueueStoreType: MEMORY, queued messages are
# retained only until broker restart.
# false -> rely on mochi-mqtt's in-memory inflight buffer.
QueuedMessagesEnabled: true

# CertRenewal: automatic TLS certificate renewal via EST (RFC 7030).
# When enabled, the broker monitors the cert's remaining lifetime and
# reenrolls via the configured EST server when 2/3 of the lifetime has passed.
# CertRenewal:
#   Enabled: true
#   EstUrl: https://ca.local:8443
#   CheckInterval: 1h
#   CertPath: ./certs/server.pem
#   KeyPath: ./certs/server-key.pem

# Provision: zero-config bootstrapping via QR code.
# A temporary HTTP listener displays a QR code encoding a one-time challenge.
# The provisioning CA presents the challenge to receive its CSR signed.
# Provision:
#   Enabled: true
#   BootstrapPort: 9443
#   ChallengeBytes: 32
